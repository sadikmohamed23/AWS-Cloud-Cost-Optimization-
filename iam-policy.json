{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadEbsAndAmiInfo",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeSnapshots",
        "ec2:DescribeVolumes",
        "ec2:DescribeImages"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DeleteSnapshots",
      "Effect": "Allow",
      "Action": "ec2:DeleteSnapshot",
      "Resource": "*"
    },
    {
      "Sid": "WriteLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    }
  ]
}
